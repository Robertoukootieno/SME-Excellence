---
const currentYear = new Date().getFullYear();
const isDev = import.meta.env.DEV;

const quickLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About Us" },
  { href: "/services", label: "Services" },
  { href: "/contact", label: "Contact" },
];

const services = [
  "ServiceNow Implementations",
  "Platform Managed Services",
  "Consulting & Advisory",
  "Platform Core Support",
];

const trustChips = ["Business First", "ServiceNow Experts", "Outcome Driven"];
---

<footer class="bg-primary-950 text-white pt-10 md:pt-14 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="rounded-2xl border border-white/15 bg-gradient-to-r from-primary-900/85 via-primary-900/70 to-accent-700/40 p-6 md:p-8 lg:p-10 shadow-xl shadow-primary-950/40">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div>
          <p class="section-label !bg-white/12 !text-primary-100 !border-white/30">Let's Build Together</p>
          <h3 class="text-2xl md:text-4xl font-heading mt-3">Ready to simplify your ServiceNow journey?</h3>
          <p class="text-primary-100/90 mt-3 max-w-2xl">From roadmap to delivery, we work with your team to create measurable and sustainable outcomes.</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Request RFP</a>
          <a href="/services" class="btn btn-ghost !text-white !border-white/35 !bg-white/10">Explore Services</a>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 py-12 md:py-14">
      <div>
        <a href="/" class="flex items-center gap-3 mb-5">
          <div class="w-11 h-11 bg-gradient-to-br from-primary-600 to-accent-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg font-heading">S</span>
          </div>
          <div class="flex flex-col">
            <span class="text-xl font-bold font-heading">SME</span>
            <span class="text-xs font-semibold text-primary-300 -mt-1 tracking-wider">EXCELLENCE</span>
          </div>
        </a>
        <p class="text-neutral-300 text-sm leading-relaxed">ServiceNow solutions, made easy and delivered right. Practical delivery with measurable business outcomes.</p>
        <div class="mt-5 flex flex-wrap gap-2.5">
          {trustChips.map((chip) => (
            <span class="text-xs px-3 py-1.5 rounded-full border border-white/20 bg-white/5 text-primary-100">{chip}</span>
          ))}
        </div>
      </div>

      <div>
        <h4 class="text-base font-semibold mb-4 text-accent-300">Quick Links</h4>
        <ul class="space-y-2.5">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-neutral-300 hover:text-accent-300 transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-base font-semibold mb-4 text-accent-300">Services</h4>
        <ul class="space-y-2.5">
          {services.map((service) => (
            <li>
              <a href="/services" class="text-neutral-300 hover:text-accent-300 transition-colors text-sm">
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-base font-semibold mb-4 text-accent-300">Contact</h4>
        <div class="space-y-3 text-sm text-neutral-300">
          <div>
            <p class="text-neutral-400">Address</p>
            <p>Nalemagervej 1</p>
            <p>9000 Aalborg, Denmark</p>
          </div>
          <div>
            <p class="text-neutral-400">CVR Number</p>
            <p>45947475</p>
          </div>
          <a href="/contact" class="inline-flex items-center gap-2 text-accent-300 hover:text-accent-200 transition-colors font-semibold">
            Start a Conversation
            <span aria-hidden="true">&rarr;</span>
          </a>
          <div class="flex items-center gap-3 pt-1">
            <a href="#" aria-label="LinkedIn" class="w-9 h-9 rounded-full border border-white/20 bg-white/5 hover:bg-white/10 transition-colors flex items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current text-primary-100" aria-hidden="true">
                <path d="M6.94 8.5H3.56V20h3.38V8.5Zm.22-3.55A1.95 1.95 0 0 0 5.2 3a1.95 1.95 0 0 0-1.96 1.95A1.95 1.95 0 0 0 5.2 6.9c1.08 0 1.96-.87 1.96-1.95ZM20 13.38c0-3.24-1.73-4.75-4.03-4.75-1.86 0-2.69 1.02-3.15 1.74V8.5H9.44c.04 1.24 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.12-.92.27-.68.88-1.38 1.9-1.38 1.34 0 1.87 1.02 1.87 2.52V20H20v-6.62Z"/>
              </svg>
            </a>
            <a href="#" aria-label="X" class="w-9 h-9 rounded-full border border-white/20 bg-white/5 hover:bg-white/10 transition-colors flex items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current text-primary-100" aria-hidden="true">
                <path d="M18.9 2H22l-6.78 7.75L23.2 22h-6.28l-4.91-6.43L6.4 22H3.3l7.25-8.29L1 2h6.43l4.43 5.86L18.9 2Zm-1.1 18h1.74L6.48 3.9H4.63L17.8 20Z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-primary-800/80 bg-primary-950/80">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-col md:flex-row justify-between items-center gap-3 text-sm">
        <p class="text-neutral-400">© {currentYear} SME-Excellence. All rights reserved.</p>
        <div class="flex items-center gap-5 text-neutral-400">
          <a href="#" class="hover:text-accent-300 transition-colors">Privacy Policy</a>
          <a href="#" class="hover:text-accent-300 transition-colors">Terms of Service</a>
          {isDev && (
            <a href="/cms/" target="_blank" rel="noopener noreferrer" class="text-accent-300 hover:text-accent-200 transition-colors">Edit Content</a>
          )}
        </div>
      </div>
    </div>
  </div>
</footer>
