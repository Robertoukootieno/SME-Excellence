---
const currentYear = new Date().getFullYear();
const isDev = import.meta.env.DEV;

const quickLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About Us" },
  { href: "/services", label: "Services" },
  { href: "/contact", label: "Contact" },
];

const services = [
  "ServiceNow Implementations",
  "Platform Managed Services",
  "Consulting & Advisory",
  "Platform Core Support",
];
---

<footer class="bg-primary-950 text-white pt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-6">
          <div class="w-10 h-10 bg-gradient-to-br from-primary-600 to-accent-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg font-heading">S</span>
          </div>
          <div class="flex flex-col">
            <span class="text-xl font-bold font-heading">SME</span>
            <span class="text-xs font-semibold text-primary-300 -mt-1 tracking-wider">EXCELLENCE</span>
          </div>
        </a>
        <p class="text-neutral-300 text-sm leading-relaxed mb-6">ServiceNow solutions, Made Easy. Done Right!</p>
        <p class="text-sm text-neutral-400">Let's build excellence together.</p>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-6 text-accent-400">Quick Links</h4>
        <ul class="space-y-3">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-neutral-300 hover:text-accent-400 transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-6 text-accent-400">Our Services</h4>
        <ul class="space-y-3">
          {services.map(service => (
            <li>
              <a href="/services" class="text-neutral-300 hover:text-accent-400 transition-colors text-sm">
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-6 text-accent-400">Contact</h4>
        <div class="space-y-4 text-sm">
          <div>
            <p class="text-neutral-400">Address</p>
            <p class="text-neutral-300">Nålemagervej 1</p>
            <p class="text-neutral-300">9000 Aalborg, Denmark</p>
          </div>
          <div>
            <p class="text-neutral-400">CVR Number</p>
            <p class="text-neutral-300">45947475</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-primary-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-neutral-400">
          © {currentYear} SME-Excellence. All rights reserved.
        </p>
        <div class="flex items-center gap-6">
          <a href="#" class="text-sm text-neutral-400 hover:text-accent-400 transition-colors">Privacy Policy</a>
          <a href="#" class="text-sm text-neutral-400 hover:text-accent-400 transition-colors">Terms of Service</a>
          {isDev && (
            <a href="/cms/" target="_blank" rel="noopener noreferrer" class="text-sm text-accent-400 hover:text-accent-300 transition-colors">Edit Content</a>
          )}
        </div>
      </div>
    </div>
  </div>
</footer>

