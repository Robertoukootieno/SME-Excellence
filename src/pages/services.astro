---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const contentEntry = await getEntry('site', 'content');

if (!contentEntry) {
  throw new Error('Missing content entry: src/content/site/content.json');
}

const servicesContent = contentEntry.data.services;
const heroImage = '/images/background_sme%202%20(1).webp';
const bannerImage = '/images/Designer%20(3).webp';

const serviceStyles = [
  { icon: '⚡', gradient: 'from-blue-500 via-primary-500 to-primary-600', bgGradient: 'from-blue-50 to-primary-50' },
  { icon: '🔧', gradient: 'from-accent-400 via-accent-500 to-orange-500', bgGradient: 'from-accent-50 to-orange-50' },
  { icon: '💡', gradient: 'from-primary-600 via-indigo-500 to-accent-500', bgGradient: 'from-primary-50 to-accent-50' }
];

const processSteps = [
  { step: '01', title: 'Discovery', description: 'We understand your needs and goals' },
  { step: '02', title: 'Design', description: 'We architect the perfect solution' },
  { step: '03', title: 'Implement', description: 'We build and configure your platform' },
  { step: '04', title: 'Optimize', description: 'We ensure peak performance' }
];

const additionalServices = [
  { title: 'Upgrades', description: 'Complete in as little as 1-2 weeks', icon: '🔄', color: 'from-green-400 to-emerald-500' },
  { title: 'CMDB/CSDM Setup & Migration', description: 'Ensure data integrity and compliance', icon: '📊', color: 'from-blue-400 to-cyan-500' },
  { title: 'Portal Development', description: 'Design and implementation of intuitive portals', icon: '🖥️', color: 'from-purple-400 to-violet-500' },
  { title: 'Custom Projects', description: 'Integrations and module implementations tailored to you', icon: '🛠️', color: 'from-accent-400 to-orange-500' }
];
---

<Layout title="Services">
  <Header />

  <section class="relative min-h-[72vh] pt-32 pb-20 text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src={heroImage} alt="ServiceNow services background" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-br from-primary-950/92 via-primary-900/80 to-primary-950/90"></div>
      <div class="hero-orb one"></div>
    </div>

    <div class="container-shell relative z-10">
      <p class="section-label !bg-white/10 !text-primary-100 !border-white/30">Services</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl mt-5 max-w-4xl">{servicesContent.heroTitle}</h1>
      <p class="text-xl text-primary-100/90 mt-5 max-w-3xl">{servicesContent.heroSubtitle}</p>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-10 max-w-3xl">
        <div class="glass-card px-4 py-4 text-center"><p class="text-2xl font-bold">4-8</p><p class="text-xs text-primary-100/80">Weeks to go-live</p></div>
        <div class="glass-card px-4 py-4 text-center"><p class="text-2xl font-bold">24/7</p><p class="text-xs text-primary-100/80">Platform support</p></div>
        <div class="glass-card px-4 py-4 text-center col-span-2 md:col-span-1"><p class="text-2xl font-bold">100%</p><p class="text-xs text-primary-100/80">Client focused</p></div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container-shell">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="section-label">Core Services</p>
        <h2 class="text-3xl md:text-5xl mt-4">What we deliver across implementation and operations</h2>
      </div>

      <div class="space-y-10">
        {servicesContent.mainServices.map((service, index) => {
          const style = serviceStyles[index] ?? serviceStyles[0];
          return (
            <article class="surface-card p-7 md:p-9">
              <div class="grid lg:grid-cols-2 gap-8">
                <div>
                  <div class={`w-16 h-16 bg-gradient-to-br ${style.gradient} rounded-2xl flex items-center justify-center text-3xl text-white`}>{style.icon}</div>
                  <h3 class="text-2xl md:text-3xl mt-5">{service.title}</h3>
                  <p class={`font-semibold mt-2 bg-gradient-to-r ${style.gradient} bg-clip-text text-transparent`}>{service.tagline}</p>
                  <p class="text-neutral-600 mt-4 leading-relaxed">{service.description}</p>
                  <a href="/contact" class="btn btn-primary mt-6">Get Started</a>
                </div>

                <div>
                  <div class={`rounded-2xl p-6 md:p-7 bg-gradient-to-br ${style.bgGradient} border border-neutral-200`}>
                    <h4 class="text-lg font-bold text-neutral-900">What is included</h4>
                    <ul class="space-y-3 mt-5">
                      {service.features.map((feature) => (
                        <li class="flex gap-3 text-neutral-700">
                          <span class="w-2.5 h-2.5 rounded-full bg-primary-600 mt-2"></span>
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section-space bg-white/70">
    <div class="container-shell">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="section-label">Delivery Process</p>
        <h2 class="text-3xl md:text-5xl mt-4">How engagements move from idea to value</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-5">
        {processSteps.map((item, index) => (
          <article class="surface-card p-6 text-center">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-r from-primary-500 to-accent-500 mx-auto text-white grid place-items-center font-bold mb-4">{item.step}</div>
            <h3 class="text-xl">{servicesContent.processSteps[index]?.title ?? item.title}</h3>
            <p class="text-neutral-600 mt-2">{servicesContent.processSteps[index]?.description ?? item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container-shell">
      <div class="grid lg:grid-cols-[1fr_1.2fr] gap-8 items-center mb-10">
        <div class="media-frame h-[20rem] md:h-[24rem]">
          <img src={bannerImage} alt="Platform enhancement and managed services collaboration" />
        </div>
        <div>
          <p class="section-label">Platform Core Support</p>
          <h2 class="text-3xl md:text-5xl mt-4">Maintenance and enhancements that keep momentum high</h2>
          <p class="text-neutral-600 mt-4">Affordable, time-bound support options to keep your platform healthy and your teams productive.</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {additionalServices.map((service, index) => (
          <article class="surface-card p-6">
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-r ${service.color} text-white text-2xl grid place-items-center`}>{service.icon}</div>
            <h3 class="text-xl mt-4">{servicesContent.additionalServices[index]?.title ?? service.title}</h3>
            <p class="text-neutral-600 mt-2">{servicesContent.additionalServices[index]?.description ?? service.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container-shell rounded-3xl p-9 md:p-12 bg-gradient-to-br from-primary-900 to-primary-800 text-white border border-white/10 shadow-2xl shadow-primary-950/30">
      <h2 class="text-3xl md:text-5xl max-w-3xl">{servicesContent.finalCtaTitle}</h2>
      <p class="text-primary-100/90 text-lg mt-4 max-w-3xl">{servicesContent.finalCtaText}</p>
      <div class="flex flex-wrap gap-3 mt-7">
        <a href="/contact" class="btn btn-primary">Request a Consultation</a>
        <a href="/about" class="btn btn-ghost !bg-white/10 !text-white !border-white/30">Learn About Us</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
