---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const contentEntry = await getEntry('site', 'content');

if (!contentEntry) {
  throw new Error('Missing content entry: src/content/site/content.json');
}

const contactContent = contentEntry.data.contact;
const heroImage = '/images/background_sme%201%20(1).webp';
const contactImage = '/images/ChatGPT%20Image%20Feb%207%2C%202026%2C%2008_31_11%20PM.webp';
---

<Layout title="Contact">
  <Header />
  
  <section class="relative min-h-[62vh] pt-32 pb-20 text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src={heroImage} alt="Contact SME-Excellence background" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-br from-primary-950/92 via-primary-900/80 to-primary-950/90"></div>
      <div class="hero-orb one"></div>
    </div>

    <div class="container-shell relative z-10">
      <p class="section-label !bg-white/10 !text-primary-100 !border-white/25">Contact Us</p>
      <h1 class="text-4xl md:text-6xl mt-5 max-w-3xl">{contactContent.heroTitle}</h1>
      <p class="text-xl text-primary-100/90 max-w-3xl mt-5">{contactContent.heroSubtitle}</p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-10 max-w-4xl">
        <div class="glass-card px-4 py-4 text-center"><p class="text-2xl font-bold">Fast</p><p class="text-xs text-primary-100/80">Response</p></div>
        <div class="glass-card px-4 py-4 text-center"><p class="text-2xl font-bold">Practical</p><p class="text-xs text-primary-100/80">Guidance</p></div>
        <div class="glass-card px-4 py-4 text-center"><p class="text-2xl font-bold">Tailored</p><p class="text-xs text-primary-100/80">Proposals</p></div>
        <div class="glass-card px-4 py-4 text-center"><p class="text-2xl font-bold">Trusted</p><p class="text-xs text-primary-100/80">Delivery</p></div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container-shell grid lg:grid-cols-[1fr_0.9fr] gap-8 items-start">
      <div class="surface-card p-7 md:p-9">
        <h2 class="text-3xl md:text-4xl">Send us a message</h2>
        <p class="text-neutral-600 mt-3">Tell us what you need and we will come back with a practical next step.</p>

        <form class="space-y-5 mt-7" id="contact-form">
            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-medium text-neutral-700 mb-2">First Name</label>
                <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all bg-white" placeholder="John" />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-neutral-700 mb-2">Last Name</label>
                <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all bg-white" placeholder="Doe" />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all bg-white" placeholder="john@company.com" />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-neutral-700 mb-2">Company</label>
              <input type="text" id="company" name="company" class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all bg-white" placeholder="Your Company" />
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-neutral-700 mb-2">Service Interest</label>
              <select id="service" name="service" class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all bg-white">
                <option value="">Select a service</option>
                {contactContent.serviceOptions.map((option) => (
                  <option value={option.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>{option}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-neutral-700 mb-2">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl border border-neutral-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all resize-none bg-white" placeholder="Tell us about your project..."></textarea>
            </div>
            <button type="submit" class="w-full btn btn-primary text-lg">
              Send Message
            </button>
          </form>
        </div>

      <aside class="space-y-6">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-r from-primary-200 to-accent-200 rounded-3xl blur-2xl opacity-40"></div>
          <div class="media-frame h-[17rem] md:h-[20rem] relative">
            <img src={contactImage} alt="Professional consultation and client communication" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary-950/60 via-transparent to-transparent"></div>
          </div>
        </div>

        <div class="surface-card p-7">
          <h2 class="text-2xl md:text-3xl">Get in touch</h2>
          <p class="text-neutral-600 mt-3 leading-relaxed">{contactContent.infoText}</p>

          <div class="space-y-5 mt-6 text-neutral-700">
            <div>
              <p class="font-semibold text-neutral-900">Address</p>
              <p>{contactContent.addressLine1}</p>
              <p>{contactContent.addressLine2}</p>
            </div>
            <div>
              <p class="font-semibold text-neutral-900">CVR Number</p>
              <p>{contactContent.cvr}</p>
            </div>
          </div>

          <div class="mt-7 rounded-2xl p-6 text-white bg-gradient-to-br from-primary-900 to-primary-800 shadow-xl">
            <h3 class="text-xl font-bold mb-3">{contactContent.rfpTitle}</h3>
            <p class="text-primary-100/90 mb-5">{contactContent.rfpText}</p>
            <a href="/contact" class="btn btn-primary">{contactContent.rfpButtonText}</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thank you for your message! We will get back to you soon.');
    form.reset();
  });
</script>

